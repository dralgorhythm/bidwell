{
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && next-image-export-optimizer",
    "build:fast": "NODE_ENV=production next build",
    "start": "next start",
    "test": "vitest",
    "test:watch": "vitest",
    "test:related": "vitest related",
    "test:coverage": "vitest run --coverage",
    "test:quick": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "qa": "npm run type-check && npm run lint && npm run test:quick",
    "qa:full": "npm run type-check && npm run lint && npm run test:coverage && npm run build",
    "preview": "npm run build && npx serve out",
    "analyze": "ANALYZE=true next build --webpack"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.1.17",
    "geist": "1.5.1",
