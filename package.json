    "react-dom": "19.2.0",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@next/bundle-analyzer": "^16.0.3",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
