{
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:static": "node scripts/build-static.js",
    "build:fast": "NODE_ENV=production next build",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:quick": "jest --passWithNoTests --silent --maxWorkers=2",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:quiet": "eslint . --ext .js,.jsx,.ts,.tsx --quiet",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "qa": "npm run type-check && npm run lint:quiet && npm run test:quick",
    "qa:full": "npm run type-check && npm run lint && npm run test:coverage && npm run build",
    "preview": "npm run build && npx serve out",
    "analyze": "ANALYZE=true npm run build"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.1.7",
    "@types/node": "22.10.5",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vercel/analytics": "1.5.0",
    "@vercel/speed-insights": "1.2.0",
    "geist": "1.4.2",
    "lightningcss": "^1.28.2",
    "next": "^15.5.2",
    "postcss": "8.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "4.1.7",
    "typescript": "5.8.3",
    "web-vitals": "^5.0.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/bundle-analyzer": "^15.4.0-canary.51",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "29.5.14",
    "audit-ci": "^7.1.0",
    "axe-core": "^4.10.3",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.4.0-canary.51",
    "eslint-config-prettier": "^10.1.5",
    "jest": "29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "29.7.0",
    "prettier": "^3.5.3",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
