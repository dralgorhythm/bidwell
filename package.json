    "@vitejs/plugin-react": "5.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "audit-ci": "^7.1.0",
    "baseline-browser-mapping": "^2.9.4",
    "jsdom": "27.2.0",
    "next-image-export-optimizer": "^1.19.0",
